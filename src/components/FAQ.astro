---
<section class="py-28 px-6 bg-white border-t border-gray-100">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
    <!-- Left Column: Sticky Header (40%) -->
    <div class="lg:col-span-5 flex flex-col justify-start">
      <span class="text-blue-600 font-mono text-xs uppercase tracking-widest mb-4">Wsparcie i Wiedza</span>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tighter text-gray-900 mb-6 leading-tight">{faq.title}</h2>
      <p class="text-lg text-gray-600 leading-relaxed">{faq.subtitle}</p>
    </div>
    
    <!-- Right Column: Collapsible Accordion items (60%) -->
    <div class="lg:col-span-7 border-t border-gray-200">
      {faq.items.map((item, index) => (
        <div class="border-b border-gray-200 faq-item">
          <!-- Accordion Title Trigger -->
          <button class="w-full flex items-center justify-between py-6 text-left group">
            <span class="text-base md:text-lg font-bold text-gray-900 group-hover:text-blue-600 transition-colors pr-4">{item.question}</span>
            <div class="text-gray-400 group-hover:text-blue-600 transition-colors shrink-0">
              <svg class="h-6 w-6 transform transition-transform duration-300 icon-plus" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
            </div>
          </button>
          
          <!-- Collapsible Body (Hidden on load) -->
          <div class="faq-answer hidden pb-6">
            <p class="text-gray-600 leading-relaxed text-sm md:text-base">{item.answer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const items = document.querySelectorAll('.faq-item');

  items.forEach(item => {
    const btn = item.querySelector('button');
    const answer = item.querySelector('.faq-answer');
    const icon = item.querySelector('.icon-plus');

    btn?.addEventListener('click', () => {
      const isHidden = answer?.classList.contains('hidden');
      
      // Auto-Close: Close all other open items first
      if (isHidden) {
        items.forEach(otherItem => {
          if (otherItem !== item) {
            otherItem.querySelector('.faq-answer')?.classList.add('hidden');
            const otherIcon = otherItem.querySelector('.icon-plus');
            otherIcon?.classList.remove('rotate-45', 'text-blue-600');
          }
        });

        // Expand clicked item
        answer?.classList.remove('hidden');
        icon?.classList.add('rotate-45', 'text-blue-600');
      } else {
        // Collapse clicked item
        answer?.classList.add('hidden');
        icon?.classList.remove('rotate-45', 'text-blue-600');
      }
    });
  });
</script>
