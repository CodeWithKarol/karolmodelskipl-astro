---
const hero = {
  h1_part1: "Tworzę wydajne",
  h1_part2: "aplikacje internetowe dla firm,",
  h1_highlight: "które automatyzują procesy i skalują zyski.",
  subheading: "Dla właścicieli firm, którzy zamiast faktur za 'głuchy telefon' potrzebują systemów generujących zwrot z inwestycji. Zyskaj architekturę klasy bankowej bez ukrytych kosztów agencji i prowizji pośredników.",
  cta: "Odbierz Bezpłatną Mapę Drogową Rozwoju IT",
  click_trigger_part1: "Kompletny Pakiet Doradczy o wartości 600 zł.",
  click_trigger_part2: "Dziś za 0 zł.",
  indicators: [
    { text: "Brak ukrytych kosztów agencji" },
    { text: "Bezpieczeństwo klasy bankowej" },
    { text: "Bezpośrednie partnerstwo" },
  ],
}
---
<section class="relative h-screen w-full overflow-hidden bg-gradient-to-br from-white to-gray-50 flex items-center justify-start px-6 md:justify-center">
  <div class="relative text-left md:text-center text-gray-900 max-w-4xl">
    <h1 class="text-4xl md:text-6xl font-bold tracking-tighter mb-6">
      {hero.h1_part1} <span class="block md:inline text-gray-600">{hero.h1_part2}</span>
      <span class="block text-blue-600 mt-2">{hero.h1_highlight}</span>
    </h1>
    <p class="text-lg md:text-xl text-gray-700 mb-8 max-w-2xl md:mx-auto">{hero.subheading}</p>
    
    <div class="flex flex-col md:items-center gap-3">
        <a href="/contact" class="bg-blue-50 text-blue-700 border border-blue-100 px-6 py-3 md:px-8 md:py-4 text-base md:text-lg font-bold rounded-full hover:bg-blue-100 transition-colors text-center">
          {hero.cta}
        </a>
      <p class="text-sm text-gray-600 font-medium">
        {hero.click_trigger_part1} <span class="text-gray-900 font-bold">{hero.click_trigger_part2}</span>
      </p>
    </div>

    <div class="mt-12 flex flex-col md:flex-row flex-wrap justify-center gap-4 md:gap-8 text-sm font-medium text-gray-700">
      {hero.indicators.map(ind => (
        <div class="flex items-center gap-2">
          <svg class="h-5 w-5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"/></svg>
          {ind.text}
        </div>
      ))}
    </div>
  </div>
</section>
